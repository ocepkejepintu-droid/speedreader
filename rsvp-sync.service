[Unit]
Description=RSVP Reader account sync API
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/rsvp-reader
EnvironmentFile=-/etc/rsvp-reader.env
Environment=RSVP_SYNC_DIR=/var/www/rsvp-reader/sync-data
Environment=RSVP_SYNC_PORT=9877
ExecStart=/usr/local/bin/node /var/www/rsvp-reader/sync-server.mjs
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
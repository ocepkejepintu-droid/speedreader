[Unit]
Description=RSVP Reader shared book summaries API
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/rsvp-reader
EnvironmentFile=-/etc/rsvp-reader.env
ExecStart=/usr/bin/node /var/www/rsvp-reader/summaries-server.mjs
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target